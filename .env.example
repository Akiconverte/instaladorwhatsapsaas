# Exemplo de configuração de ambiente
# Copie este arquivo para .env e preencha com seus dados

# Credenciais GitHub (opcional - se não informado, serão solicitadas)
GITHUB_USERNAME=seu_username
GITHUB_TOKEN=seu_token_pessoal

# Senha para usuários do sistema
DEPLOY_PASSWORD=sua_senha_forte
MYSQL_ROOT_PASSWORD=sua_senha_mysql
DB_PASS=sua_senha_banco

# Email para certificados SSL
DEPLOY_EMAIL=seu@email.com
